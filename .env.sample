# =============================================================================
# SPFirmwares Environment Configuration (.env.sample)
# =============================================================================
# Copy this file to `.env` and adjust the values for each environment.
# All values are UTF-8 text; line endings must be LF (\n) for portability.
#
# NEVER commit a real .env file with secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Django settings
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY
DJANGO_DEBUG=0                 # 1 for local development, 0 for production
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Optional Django site identifier (django.contrib.sites)
SITE_ID=1

# -----------------------------------------------------------------------------
# Database configuration
# -----------------------------------------------------------------------------
# Postgres is required (SQLite is no longer supported).
DB_ENGINE=django.db.backends.postgresql
DB_NAME=SPFirmwares
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5433

# -----------------------------------------------------------------------------
# Proxy / load balancer awareness
# -----------------------------------------------------------------------------
# Number of trusted proxy hops in X-Forwarded-For; 0 = disabled.
TRUSTED_PROXY_COUNT=0

# -----------------------------------------------------------------------------
# Email (optional – will default to console backend in development)
# -----------------------------------------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=postmaster@example.com
# EMAIL_HOST_PASSWORD=CHANGE_ME_EMAIL_PASSWORD
# EMAIL_USE_TLS=1

# -----------------------------------------------------------------------------
# Caching (optional – local memory cache is safe default)
# -----------------------------------------------------------------------------
# CACHE_URL=redis://localhost:6379/1

# -----------------------------------------------------------------------------
# Logging / Sentry / Observability (optional)
# -----------------------------------------------------------------------------
# SENTRY_DSN=https://public-key@o000000.ingest.sentry.io/000000
# SENTRY_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Third-party integrations (optional – configure as needed)
# -----------------------------------------------------------------------------
# SOCIAL_AUTH_GOOGLE_CLIENT_ID=your_google_client_id_here
# SOCIAL_AUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# SOCIAL_AUTH_GITHUB_CLIENT_ID=your_github_client_id_here
# SOCIAL_AUTH_GITHUB_CLIENT_SECRET=your_github_client_secret_here

# -----------------------------------------------------------------------------
# Local overrides
# -----------------------------------------------------------------------------
# Add any extra, project-specific flags here. Keep names UPPER_CASE.
# FEATURE_FLAG_SOMETHING=0
