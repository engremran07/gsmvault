# Production keystore configuration template.
# Copy this file to android/key.properties and fill in the values.
# NEVER commit key.properties to version control.
#
# To create a keystore:
#   keytool -genkey -v -keystore ~/ac_techs_release.jks \
#           -keyalg RSA -keysize 2048 -validity 10000 \
#           -alias ac_techs
#
storeFile=/path/to/ac_techs_release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=ac_techs
keyPassword=YOUR_KEY_PASSWORD
