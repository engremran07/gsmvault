rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveUser() {
      return isAuthenticated() && userDoc().data.active == true;
    }

    function getUserRole() {
      return userDoc().data.role;
    }

    function isAdminRole(role) {
      return role is string && role.matches('(?i)^\\s*(admin|manager)\\s*$');
    }

    function isSellerRole(role) {
      return role is string && role.matches('(?i)^\\s*seller\\s*$');
    }

    function assignedRouteId() {
      return userDoc().data.assigned_route_id;
    }

    function isAdmin() {
      return isActiveUser() && isAdminRole(getUserRole());
    }

    function isSeller() {
      return isActiveUser() && isSellerRole(getUserRole());
    }

    function isOwnDoc(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // S-07: cap document field count (request.resource.data.size() returns
    // field count, NOT byte size). 100 fields is a generous upper bound for
    // any document in this schema.
    function docSizeOk() {
      return request.resource.data.size() < 100;
    }

    // BUG-02: Sellers may only create cash_in or cash_out transactions.
    // Admin-only types: return, payment, write_off.
    function isValidSellerTransactionType(type) {
      return type == 'cash_in' || type == 'cash_out';
    }

    // Write-rate guard: at least 1 second between writes (prevent rapid-fire)
    function withinWriteRate() {
      return resource == null
        || !('updated_at' in resource.data)
        || request.time > resource.data.updated_at + duration.value(1, 's');
    }

    function isBootstrapAdminCreate(userId) {
      return isOwnDoc(userId)
        && !exists(/databases/$(database)/documents/users/$(userId))
        && !exists(/databases/$(database)/documents/settings/global)
        && request.resource.data.role == 'admin'
        && request.resource.data.active == true;
    }

    function isSellerForRoute(routeId) {
      return isSeller() && assignedRouteId() != null && assignedRouteId() == routeId;
    }

    // Returns the route_id for a shop/customer document.
    // Using a single get() avoids an extra exists() read on every check.
    function shopRouteId(shopId) {
      return get(/databases/$(database)/documents/customers/$(shopId)).data.route_id;
    }

    // True when the seller owns the route the given shop belongs to.
    function isSellerForShop(shopId) {
      return isSeller() &&
        shopId is string &&
        shopId != '' &&
        shopRouteId(shopId) == assignedRouteId();
    }

    // True when a transaction doc belongs to the seller's assigned route.
    // Checks route_id field first (fast, no cross-doc lookup);
    // falls back to shop_id for docs missing route_id.
    function isSellerRouteTransaction() {
      return isSeller() && (
        (resource.data.route_id != null &&
         resource.data.route_id != '' &&
         isSellerForRoute(resource.data.route_id)) ||
        (resource.data.shop_id != null &&
         resource.data.shop_id != '' &&
         isSellerForShop(resource.data.shop_id))
      );
    }

    // Same as isSellerRouteTransaction() but for incoming writes.
    function requestIsSellerRouteTransaction() {
      return isSeller() && (
        (request.resource.data.route_id != null &&
         request.resource.data.route_id != '' &&
         isSellerForRoute(request.resource.data.route_id)) ||
        (request.resource.data.shop_id != null &&
         request.resource.data.shop_id != '' &&
         isSellerForShop(request.resource.data.shop_id))
      );
    }

    // Validates an allowed transaction type value
    function isValidTransactionType(type) {
      return type is string &&
        (type == 'cash_out' || type == 'cash_in' || type == 'return' ||
         type == 'payment' || type == 'write_off');
    }

    // Validates role values to prevent arbitrary role strings being stored
    function isValidRole(role) {
      return role is string &&
        role.matches('(?i)^\\s*(admin|manager|seller)\\s*$');
    }

    function requiresSellerTransactionEditApproval() {
      return get(/databases/$(database)/documents/settings/global)
        .data.require_admin_approval_for_seller_transaction_edits == true;
    }

    // --- users --------------------------------------------------------------
    match /users/{userId} {
      // get (single doc): own doc or admin
      allow get: if isOwnDoc(userId) || isAdmin();
      // list (collection query): admin only — avoids per-doc wildcard ambiguity
      allow list: if isAdmin();
      allow create: if (isBootstrapAdminCreate(userId) ||
        (
          isAdmin() &&
          request.resource.data.created_by == request.auth.uid &&
          isValidRole(request.resource.data.role) &&
          (
            request.resource.data.role != 'seller' ||
            (
              request.resource.data.assigned_route_id is string &&
              request.resource.data.assigned_route_id != ''
            )
          )
        )) && docSizeOk();
      allow update: if (
        // Admin can update any user fields (including route assignment) without
        // client write-rate throttling, which otherwise blocks bulk assignment.
        (isAdmin() && docSizeOk()) ||
        (
          isOwnDoc(userId) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['display_name', 'updated_at', 'last_active', 'email_verified']) &&
          docSizeOk() &&
          withinWriteRate()
        )
      );
      allow delete: if isAdmin();
    }

    // --- products -----------------------------------------------------------
    match /products/{productId} {
      allow read: if isActiveUser();
      allow create, update: if isAdmin() && docSizeOk();
      allow delete: if isAdmin();
    }

    // --- product_variants ---------------------------------------------------
    match /product_variants/{variantId} {
      allow read: if isActiveUser();
      allow create: if isAdmin() && docSizeOk();
      allow update: if isAdmin() && docSizeOk();
      allow delete: if isAdmin();
    }

    // --- routes -------------------------------------------------------------
    match /routes/{routeId} {
      allow read: if isAdmin() || isSellerForRoute(routeId);
      allow create, update: if isAdmin() && docSizeOk();
      allow delete: if isAdmin();
    }

    // --- customers (= shops) ------------------------------------------------
    // This collection stores RETAIL SHOPS only. The collection name 'customers'
    // is legacy and kept to avoid a data migration. App code uses ShopModel
    // and Collections.shops alias. No separate Customer entity exists.
    //
    // BALANCE FIELD: balance > 0 means shop owes us money (accounts receivable).
    // Updated atomically with every transaction/invoice write.
    match /customers/{customerId} {
      allow read: if isAdmin() ||
        (
          isSeller() &&
          resource.data.route_id != null &&
          isSellerForRoute(resource.data.route_id)
        );
      // Sellers must include a non-empty route_id when creating customers
      allow create: if (isAdmin() ||
        (
          isSeller() &&
          request.resource.data.route_id is string &&
          request.resource.data.route_id != '' &&
          isSellerForRoute(request.resource.data.route_id)
        )) && docSizeOk();
      // Sellers can update customers in their own route only.
      // SR-08: withinWriteRate() removed from customers — financial ledger writes
      // (balance increments from invoice batches) must not be throttled; atomic
      // WriteBatch integrity is the correct guard, not a 1-second time gate.
      allow update: if (isAdmin() ||
        (
          isSeller() &&
          resource.data.route_id is string &&
          resource.data.route_id != '' &&
          isSellerForRoute(resource.data.route_id)
        )) && docSizeOk();
      allow delete: if isAdmin();
    }

    // --- transactions -------------------------------------------------------
    // Ledger entries for shop accounts. Two creation pathways:
    //   1. Via InvoiceNotifier.createSaleInvoice() \u2014 sale with stock deduction
    //      (type: cash_out, linked via invoice_id + invoice_number)
    //   2. Via TransactionNotifier.create() \u2014 cash collection from existing debt
    //      (type: cash_in, no invoice_id, no items)
    // Allowed types: cash_in | cash_out | return | payment | write_off
    match /transactions/{txId} {
      // Seller can read only route-owned transactions.
      allow read: if isAdmin() || isSellerRouteTransaction();
      // Field validation: type must be in allowed set, amount must be positive
      allow create: if (isAdmin() ||
        (
          isSeller() &&
          request.resource.data.created_by == request.auth.uid &&
          request.resource.data.shop_id != null &&
          request.resource.data.shop_id != '' &&
          isValidSellerTransactionType(request.resource.data.type) &&
          request.resource.data.amount is number &&
          request.resource.data.amount > 0 &&
          request.resource.data.route_id != null &&
          request.resource.data.route_id != '' &&
          isSellerForRoute(request.resource.data.route_id) &&
          isSellerForShop(request.resource.data.shop_id)
        )) && docSizeOk()
        // Admin also requires valid type and positive amount for integrity
        && (isSeller() || (
          isValidTransactionType(request.resource.data.type) &&
          request.resource.data.amount is number &&
          request.resource.data.amount > 0
        ));
      // Admins can update all financial fields.
      // Sellers can:
      // 1) submit edit request fields when approval toggle is ON
      // 2) directly edit own cash_in/cash_out transactions when toggle is OFF
      allow update: if isAdmin() ||
        (
          requestIsSellerRouteTransaction() &&
          (
            (
              requiresSellerTransactionEditApproval() &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'description',
                'updated_at',
                'updated_by',
                'edit_request_pending',
                'edit_request_status',
                'edit_request_requested_by',
                'edit_request_requested_at',
                'edit_request_new_amount',
                'edit_request_new_type',
                'edit_request_new_description',
                'edit_request_new_sale_type',
                'edit_request_new_created_at'
              ]) &&
              request.resource.data.edit_request_pending == true &&
              request.resource.data.edit_request_status == 'pending'
            ) ||
            (
              !requiresSellerTransactionEditApproval() &&
              resource.data.created_by == request.auth.uid &&
              request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'description',
                'updated_at',
                'updated_by',
                'edit_request_pending',
                'edit_request_status',
                'edit_request_reviewed_by',
                'edit_request_reviewed_at',
                'edit_request_new_amount',
                'edit_request_new_type',
                'edit_request_new_description',
                'edit_request_new_sale_type',
                'edit_request_new_created_at'
              ])
            )
          )
        );
      allow delete: if isAdmin();
    }

    // --- seller inventory ---------------------------------------------------
    match /seller_inventory/{docId} {
      allow read: if isAdmin() ||
        (isSeller() && resource.data.seller_id == request.auth.uid);
      allow create, delete: if isAdmin();
      // Seller can update quantity_available (stock deduction on sale).
      // Post-state quantity_available must stay >= 0 to prevent negative stock.
      // SR-07: withinWriteRate() intentionally excluded here — rapid sequential
      // sales (two invoices < 1 ms apart) would otherwise block the second
      // stock deduction, creating ghost inventory discrepancies. The
      // quantity_available >= 0 guard is the true integrity constraint.
      allow update: if (isAdmin() ||
        (
          isSeller() &&
          resource.data.seller_id == request.auth.uid &&
          request.resource.data.quantity_available >= 0 &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['quantity_available', 'updated_at'])
        )) && docSizeOk();
    }

    // --- inventory transactions (audit log for all stock movements) ---------
    match /inventory_transactions/{docId} {
      allow read: if isAdmin() ||
        (isSeller() && resource.data.seller_id == request.auth.uid);
      allow create: if (isAdmin() ||
        (
          isSeller() &&
          request.resource.data.seller_id == request.auth.uid &&
          request.resource.data.created_by == request.auth.uid
        )) && docSizeOk();
      allow update, delete: if isAdmin();
    }

    // --- settings -----------------------------------------------------------
    match /settings/{docId} {
      allow read: if isActiveUser();
      allow create, delete: if isAdmin();
      // Admin: full update.
      // Sellers: only invoice counter — and only increment by exactly 1 to
      // prevent fraudulent bulk increments of the invoice sequence.
      allow update: if (isAdmin() ||
        (isActiveUser() &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['last_invoice_number']) &&
         request.resource.data.last_invoice_number ==
           resource.data.last_invoice_number + 1)) && docSizeOk();
    }

    // --- invoices -----------------------------------------------------------
    match /invoices/{invoiceId} {
      allow read: if isAdmin() ||
        (
          isSeller() && (
            resource.data.seller_id == request.auth.uid ||
            (resource.data.route_id != null &&
             resource.data.route_id != '' &&
             isSellerForRoute(resource.data.route_id))
          )
        );
      allow create: if (isAdmin() ||
        (
          isSeller() &&
          request.resource.data.created_by == request.auth.uid &&
          request.resource.data.shop_id != null &&
          request.resource.data.shop_id != '' &&
          request.resource.data.route_id != null &&
          request.resource.data.route_id != '' &&
          isSellerForRoute(request.resource.data.route_id) &&
          isSellerForShop(request.resource.data.shop_id)
        ))
        // Invoice math integrity: total must equal subtotal minus discount
        && request.resource.data.total is number
        && request.resource.data.subtotal is number
        && request.resource.data.discount is number
        && request.resource.data.amount_received is number
        && request.resource.data.amount_received >= 0
        && request.resource.data.amount_received <= request.resource.data.total + 0.01
        && request.resource.data.total >= request.resource.data.subtotal - request.resource.data.discount - 0.01
        && request.resource.data.total <= request.resource.data.subtotal - request.resource.data.discount + 0.01
        && docSizeOk();
      allow update: if isAdmin() && docSizeOk();
      allow delete: if isAdmin();
    }

    // --- admin_config (SA credentials for admin auth pipeline) ---------------
    // Only admins can read. Never written from client code.
    // Provisioned once via setup script (functions/admin_fix_passwords.js).
    match /admin_config/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- Deny all other paths -----------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
